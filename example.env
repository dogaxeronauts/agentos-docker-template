# Required (default configured for OpenAI)
OPENAI_API_KEY=sk-***

# Optional: Use a different model provider
# ANTHROPIC_API_KEY=sk-ant-***
# GOOGLE_API_KEY=***

# Database (defaults work out of the box)
# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai

# Scheduler (set in production to point to your AgentOS URL)
# AGENTOS_URL=https://your-agentos-url.com
